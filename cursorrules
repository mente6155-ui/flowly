## Backend - Manejo de Errores en Node.js

### Clase de Error Personalizada
```javascript
// utils/AppError.js
class AppError extends Error {
  constructor(message, statusCode, code) {
    super(message);
    this.statusCode = statusCode;
    this.code = code;
    this.isOperational = true;
  }
}

// Errores predefinidos
AppError.notFound = (resource) => 
  new AppError(`${resource} no encontrado`, 404, 'NOT_FOUND');

AppError.unauthorized = () => 
  new AppError('No autorizado', 401, 'UNAUTHORIZED');

AppError.badRequest = (msg) => 
  new AppError(msg, 400, 'BAD_REQUEST');
```

### Middleware de Errores Global
```javascript
// middleware/errorHandler.js
const errorHandler = (err, req, res, next) => {
  console.error(`[ERROR] ${err.message}`, {
    stack: err.stack,
    url: req.url,
    method: req.method,
  });

  if (err.isOperational) {
    return res.status(err.statusCode).json({
      success: false,
      error: { code: err.code, message: err.message }
    });
  }

  // Error inesperado - no revelar detalles
  res.status(500).json({
    success: false,
    error: { 
      code: 'INTERNAL_ERROR',
      message: 'Error interno del servidor'
    }
  });
};
```

### Try-Catch en Controladores
```javascript
// ✅ SIEMPRE usa este patrón en controllers
const asyncHandler = (fn) => (req, res, next) => {
  Promise.resolve(fn(req, res, next)).catch(next);
};

// Uso:
router.get('/workflows', asyncHandler(async (req, res) => {
  const workflows = await WorkflowService.getAll(req.user.id);
  res.json({ success: true, data: workflows });
}));
```


